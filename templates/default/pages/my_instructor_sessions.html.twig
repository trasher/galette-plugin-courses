{% extends "page.html.twig" %}

{% block content %}

{# =========================================================
   Préparer les données : 4 buckets selon date / statut
   ========================================================= #}
{% set upcoming_active = [] %}
{% set upcoming_cancelled = [] %}
{% set past = [] %}
{% for sid, s in sessions %}
    {% if s.getSessionDate() >= "now"|date("Y-m-d") %}
        {% if s.getStatus() == 'cancelled' %}
            {% set upcoming_cancelled = upcoming_cancelled|merge([sid]) %}
        {% else %}
            {% set upcoming_active = upcoming_active|merge([sid]) %}
        {% endif %}
    {% else %}
        {% set past = past|merge([sid]) %}
    {% endif %}
{% endfor %}

{# Grouper la prochaine date #}
{% set next_group = [] %}
{% set rest_group = [] %}
{% if upcoming_active|length > 0 %}
    {% set next_date = sessions[upcoming_active|first].getSessionDate() %}
    {% for sid in upcoming_active %}
        {% if sessions[sid].getSessionDate() == next_date %}
            {% set next_group = next_group|merge([sid]) %}
        {% else %}
            {% set rest_group = rest_group|merge([sid]) %}
        {% endif %}
    {% endfor %}
{% endif %}

{% if sessions|length == 0 %}
    <div class="ui placeholder segment">
        <div class="ui icon header">
            <i class="chalkboard teacher icon" aria-hidden="true"></i>
            {{ _T("You are not assigned as instructor for any session.", "courses") }}
        </div>
    </div>
{% else %}

    {# =========================================================
       Prochaine séance (toutes celles à la date la plus proche)
       ========================================================= #}
    {% if next_group|length > 0 %}
        <h3 class="ui header courses-section-mt-sm">
            <i class="star icon" aria-hidden="true"></i>
            {{ _T("Your next session", "courses") }}
        </h3>
        <div class="ui stackable three column grid courses-cards-grid">
            {% for sid in next_group %}
                {% set s = sessions[sid] %}
                {% set ev = events[s.getEventId()] %}
                <div class="column">
                    <div class="ui fluid card courses-card courses-next-session">
                        <div class="content">
                            <div class="right floated meta">
                                <span class="ui green label">{{ s.getStatusLabel() }}</span>
                            </div>
                            <a class="header" href="{{ url_for("coursesEventShow", {"id": ev.getId()}) }}">
                                {{ ev.getName() }}
                            </a>
                            <div class="meta">
                                <i class="calendar icon" aria-hidden="true"></i>
                                <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                                <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                                &nbsp;&middot;&nbsp;
                                {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                            </div>
                            {% if ev.getLocation() %}
                                <div class="meta">
                                    <i class="map pin icon" aria-hidden="true"></i>
                                    {{ ev.getLocation() }}
                                </div>
                            {% endif %}
                            {% if instructor_names[sid] is defined %}
                                <div class="meta">
                                    <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                    {{ instructor_names[sid] }}
                                </div>
                            {% endif %}
                            {% if s.getMaxCapacity() %}
                                <div class="ui tiny progress courses-section-mt-sm{% if s.isFull() %} red{% elseif s.getCapacityPercent() > 75 %} yellow{% else %} green{% endif %}" data-percent="{{ s.getCapacityPercent() }}">
                                    <div class="bar" style="width:{{ s.getCapacityPercent() }}%"></div>
                                    <div class="label">{{ s.getCurrentRegistrations() }} / {{ s.getMaxCapacity() }}</div>
                                </div>
                            {% else %}
                                <div class="meta">
                                    <i class="users icon" aria-hidden="true"></i>
                                    {{ s.getCurrentRegistrations() }} {{ _T("registered", "courses") }}
                                </div>
                            {% endif %}
                        </div>
                        <div class="extra content">
                            <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui small primary button">
                                <i class="eye icon" aria-hidden="true"></i>
                                {{ _T("Details", "courses") }}
                            </a>
                            <a href="{{ url_for("coursesSessionIcal", {"id": sid}) }}" class="ui mini icon button" title="{{ _T("Export iCal", "courses") }}">
                                <i class="calendar download icon" aria-hidden="true"></i>
                            </a>
                            {% if can_export %}
                                <a href="{{ url_for("coursesSessionExportRegistrations", {"id": sid}) }}" class="ui mini icon button" title="{{ _T("Export to CSV (Excel)", "courses") }}">
                                    <i class="file excel icon" aria-hidden="true"></i>
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        {# Autres séances à venir #}
        {% if rest_group|length > 0 %}
            <h3 class="ui header courses-section-mt">
                <i class="clock icon" aria-hidden="true"></i>
                {{ _T("Upcoming", "courses") }}
            </h3>
            <div class="ui stackable three column grid courses-cards-grid">
                {% for sid in rest_group %}
                    {% set s = sessions[sid] %}
                    {% set ev = events[s.getEventId()] %}
                    <div class="column">
                        <div class="ui fluid card courses-card">
                            <div class="content">
                                <div class="right floated meta">
                                    <span class="ui green label">{{ s.getStatusLabel() }}</span>
                                </div>
                                <a class="header" href="{{ url_for("coursesEventShow", {"id": ev.getId()}) }}">
                                    {{ ev.getName() }}
                                </a>
                                <div class="meta">
                                    <i class="calendar icon" aria-hidden="true"></i>
                                    <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                                    <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                                    &nbsp;&middot;&nbsp;
                                    {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                                </div>
                                {% if ev.getLocation() %}
                                    <div class="meta">
                                        <i class="map pin icon" aria-hidden="true"></i>
                                        {{ ev.getLocation() }}
                                    </div>
                                {% endif %}
                                {% if instructor_names[sid] is defined %}
                                    <div class="meta">
                                        <i class="chalkboard teacher icon" aria-hidden="true"></i>
                                        {{ instructor_names[sid] }}
                                    </div>
                                {% endif %}
                                {% if s.getMaxCapacity() %}
                                    <div class="ui tiny progress courses-section-mt-sm{% if s.isFull() %} red{% elseif s.getCapacityPercent() > 75 %} yellow{% else %} green{% endif %}" data-percent="{{ s.getCapacityPercent() }}">
                                        <div class="bar" style="width:{{ s.getCapacityPercent() }}%"></div>
                                        <div class="label">{{ s.getCurrentRegistrations() }} / {{ s.getMaxCapacity() }}</div>
                                    </div>
                                {% else %}
                                    <div class="meta">
                                        <i class="users icon" aria-hidden="true"></i>
                                        {{ s.getCurrentRegistrations() }} {{ _T("registered", "courses") }}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="extra content">
                                <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui small primary button">
                                    <i class="eye icon" aria-hidden="true"></i>
                                    {{ _T("Details", "courses") }}
                                </a>
                                <a href="{{ url_for("coursesSessionIcal", {"id": sid}) }}" class="ui mini icon button" title="{{ _T("Export iCal", "courses") }}">
                                    <i class="calendar download icon" aria-hidden="true"></i>
                                </a>
                                {% if can_export %}
                                    <a href="{{ url_for("coursesSessionExportRegistrations", {"id": sid}) }}" class="ui mini icon button" title="{{ _T("Export to CSV (Excel)", "courses") }}">
                                        <i class="file excel icon" aria-hidden="true"></i>
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    {% else %}
        <div class="ui info message">
            <i class="info circle icon" aria-hidden="true"></i>
            {{ _T("No upcoming session", "courses") }}
        </div>
    {% endif %}

    {# =========================================================
       Annulées (futures)
       ========================================================= #}
    {% if upcoming_cancelled|length > 0 %}
        <div class="ui red segment courses-section-mt">
            <h3 class="ui red header">
                <i class="ban icon" aria-hidden="true"></i>
                {{ _T("Cancelled sessions", "courses") }}
                <span class="ui red circular label">{{ upcoming_cancelled|length }}</span>
            </h3>
            <div class="ui stackable three column grid courses-cards-grid">
                {% for sid in upcoming_cancelled %}
                    {% set s = sessions[sid] %}
                    {% set ev = events[s.getEventId()] %}
                    <div class="column">
                        <div class="ui fluid card courses-card courses-card-cancelled">
                            <div class="content">
                                <div class="right floated meta">
                                    <span class="ui red label">{{ _T("Cancelled", "courses") }}</span>
                                </div>
                                <div class="header">{{ ev.getName() }}</div>
                                <div class="meta">
                                    <i class="calendar icon" aria-hidden="true"></i>
                                    <span class="courses-date-day">{{ s.getSessionDate()|date("d") }}</span>
                                    <span class="courses-date-month">{{ s.getMonthYear() }}</span>
                                    &nbsp;&middot;&nbsp;
                                    {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                                </div>
                                {% if ev.getLocation() %}
                                    <div class="meta">
                                        <i class="map pin icon" aria-hidden="true"></i>
                                        {{ ev.getLocation() }}
                                    </div>
                                {% endif %}
                                {% if s.getCancellationReason() %}
                                    <div class="courses-cancel-detail">
                                        <strong>{{ _T("Reason:", "courses") }}</strong>
                                        {{ s.getCancellationReasonLabel() }}
                                    </div>
                                {% endif %}
                                {% if s.getCancellationComment() %}
                                    <div class="courses-cancel-detail">
                                        <i class="comment outline icon" aria-hidden="true"></i>
                                        {{ s.getCancellationComment() }}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="extra content">
                                <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui small primary button">
                                    <i class="eye icon" aria-hidden="true"></i>
                                    {{ _T("Details", "courses") }}
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {# =========================================================
       Passées (repliable)
       ========================================================= #}
    {% if past|length > 0 %}
        <div class="courses-past-toggle courses-section-mt">
            <i class="dropdown icon" aria-hidden="true"></i>
            {{ _T("Past sessions", "courses") }} ({{ past|length }})
        </div>
        <div class="courses-past-content">
            <div class="ui stackable three column grid courses-cards-grid">
                {% for sid in past|reverse %}
                    {% set s = sessions[sid] %}
                    {% set ev = events[s.getEventId()] %}
                    <div class="column">
                        <div class="ui fluid card courses-card courses-past{% if s.getStatus() == 'cancelled' %} courses-card-cancelled{% endif %}">
                            <div class="content">
                                <div class="header">{{ ev.getName() }}</div>
                                <div class="meta">
                                    <i class="calendar icon" aria-hidden="true"></i>
                                    {{ s.getFormattedDate() }}
                                    &nbsp;&middot;&nbsp;
                                    {{ s.getFormattedStartTime() }} - {{ s.getFormattedEndTime() }}
                                </div>
                                <div class="meta">
                                    <i class="users icon" aria-hidden="true"></i>
                                    {{ s.getCurrentRegistrations() }} {{ _T("registered", "courses") }}
                                </div>
                            </div>
                            <div class="extra content">
                                {% if s.getStatus() == 'cancelled' %}
                                    <span class="ui red tiny label">
                                        <i class="ban icon" aria-hidden="true"></i>
                                        {{ _T("Cancelled", "courses") }}
                                    </span>
                                {% else %}
                                    <span class="ui label">{{ s.getStatusLabel() }}</span>
                                {% endif %}
                                <a href="{{ url_for("coursesSessionShow", {"id": sid}) }}" class="ui mini button">
                                    <i class="eye icon" aria-hidden="true"></i>
                                    {{ _T("Details", "courses") }}
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

{% endif %}

{% endblock %}

{% block javascripts %}
<script>
$(function() {
    $('.ui.progress').progress();

    // Past sessions collapsible
    $('.courses-past-content').hide();
    $('.courses-past-toggle').on('click', function() {
        $(this).next('.courses-past-content').slideToggle(200);
        $(this).find('.dropdown.icon').toggleClass('rotated');
    });
});
</script>
{% endblock %}
